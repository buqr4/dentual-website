# Bu dosya yalnızca CI/CD (GitHub Actions) ve ileride backend için referanstır.
# Statik sitede analitik ID'leri js/analytics.js içindeki CONFIG'e yazılır (build yok).
# .env'i ASLA commit etmeyin (.gitignore'da).

# --- GitHub Actions → Cloudflare Pages (repo secrets olarak ekleyin) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Analitik (js/analytics.js CONFIG'e elle yazılır) ---
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
CLARITY_PROJECT_ID=
SENTRY_DSN=

# --- Arama motoru doğrulama (DNS TXT tercih edilir) ---
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
